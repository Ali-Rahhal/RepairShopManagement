@page
@model RepairShop.Areas.Admin.Pages.DefectiveUnits.IndexModel
@{
    ViewData["Title"] = "Defective Units";
}
@using RepairShop.Models.Helpers

@Html.AntiForgeryToken()

<div class="card shadow border-0 my-4">
    <div class="card-header text-white bg-primary bg-gradient m-lg-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="text-white py-2">Defective Units Reports</h2>
            </div>
        </div>
    </div>
    <div class="card-body p-4">
        <div class="row pb-3">
            <div class="col-6">
                <!-- Filters -->
                <div class="row align-items-center">
                    <input hidden id="isAdmin" value="@User.IsInRole(SD.Role_Admin).ToString()" />
                    <div class="col-auto">
                        <label for="statusFilter" class="col-form-label fw-bold">Filter by Status:</label>
                    </div>
                    <div class="col-auto">
                        <select id="statusFilter" class="form-select form-select-sm">
                            <option value="All">All</option>
                            <option value=@(SD.Status_DU_Reported)>Reported</option>
                            @if (Env.Feature_DUQuotationStatus)
                            {
                                <option value=@(SD.Status_DU_QuotationSent)>Quotation Sent</option>
                                <option value=@(SD.Status_DU_QuotationConfirmed)>Quotation Confirmed</option>
                            }
                            <option value=@(SD.Status_DU_UnderRepair)>Under Repair</option>
                            <option value=@(SD.Status_DU_Fixed)>Fixed</option>
                            <option value=@(SD.Status_DU_OutOfService)>Out of Service</option>
                        </select>
                    </div>
                    <div class="col-auto">
                        <button type="button" class="btn btn-sm btn-warning" onclick="clearFilters()">
                            <i class="bi bi-x-circle"></i>
                        </button>
                    </div>
                </div>
            </div>
            <div class="col-6 text-end">
                <a asp-page="Upsert" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> Report Defective Unit
                </a>
            </div>
        </div>
        <div class="table-responsive">
            <table id="tblData" class="table table-bordered table-striped" style="width:100%">
                <thead>
                    <tr class="table-primary">
                        <th>Serial Number</th>
                        <th>Model</th>
                        <th>Client</th>
                        <th>Branch</th>
                        <th>Reported Date</th>
                        <th>Has Accs.</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th>Days Since Reported</th>
                        <th>Coverage</th>
                        <th>Resolved Date</th>
                        <th>Paid</th>
                        <th></th>
                    </tr>
                </thead>
            </table>
        </div>
        <div class="modal fade" id="notesModal" tabindex="-1">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5>Working Notes</h5>
                        <button class="btn-close"
                                data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div id="notesContainer"
                            style="max-height:350px;overflow-y:auto">
                        </div>
                        <hr />
                        <textarea id="newNote"
                                class="form-control"
                                rows="4"
                                placeholder="Write a new note..."></textarea>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-success"
                                onclick="addNote()">
                            <i class="bi bi-plus-circle"></i>
                            Add Note
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    window.Env = {
        Feature_DUQuotationStatus: '@Env.Feature_DUQuotationStatus',
        Feature_DUNotes: '@Env.Feature_DUNotes'
    };
</script>
@section Scripts {
    <script src="~/js/defectiveunit.js" asp-append-version="true"></script>
}